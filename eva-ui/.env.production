# Production build defaults to SAME-ORIGIN — the SPA is served by the ANIMA
# backend (or sits behind a reverse proxy), so blank = call the same host.
#
# For a STANDALONE frontend pointed at a remote backend, override these at build
# time (e.g. in .env.production.local, gitignored, or the build environment):
#   VITE_API_BASE=https://your-anima-host:8420
#   VITE_WS_BASE=your-anima-host:8420
VITE_API_BASE=
VITE_WS_BASE=
