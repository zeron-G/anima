# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
# build artifact: config/prompts/skills/seed mirrored into the package at build (see setup.py)
anima/_resources/

# Virtual environments
.venv/
venv/

# Runtime data (local, regenerated at runtime)
data/anima.db
data/anima.db-shm
data/anima.db-wal
data/chroma/
data/logs/*
data/notes/*
data/workspace/*
data/uploads/*
data/credentials/
data/user_profile.md
data/environment.md
data/projects.md
data/node.json
data/scheduler.json
data/sync_watermarks.json
data/watchdog_heartbeat.json
data/spawn*.tar.gz
data/memory.db
data/anima.lock
data/voice/
data/evolution_checkpoint.json
data/env_catalog.json
data/issues/
data/user_profile.md.*
!data/.gitkeep
!data/**/.gitkeep
!data/user_profile.md.example

# Local environment (machine-specific, NEVER commit)
local/env.yaml
!local/env.yaml.example

# Secrets (NEVER commit)
.env
.env.*
!.env.example
# build-time config template (no secrets) — intentionally tracked
!eva-ui/.env.production

# Live persona instances are PRIVATE — only the published seed (agents/_seed)
# is tracked. `anima init` copies the seed into $ANIMA_HOME/agents/<name>, which
# then evolves privately (feelings/growth_log/persona_state/lorebook/memory) and
# never flows back into the kernel repo.
/agents/*
!/agents/_seed/

# Runtime state (regenerated)
data/evolution.db
data/evolution_memory.yaml
data/evolution_state.json
data/todo_reminder_state.json
data/conversation_summary.json
data/.guardian/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini
$null

# Large model/binary files
*.vrm
anima/dashboard/static/model/PurpleBird/*.moc3
anima/dashboard/static/model/PurpleBird/*.png
anima/dashboard/static/model/PurpleBird/*.cfg
anima/desktop/frontend/model/

# Test/build
.pytest_cache/
htmlcov/
.coverage
tests/_[!_]*.py

# Dev tools output
tools/vrm_report.txt

# Temporary/debug scripts (root level only — anchored so it never ignores
# nested package __init__.py / __main__.py)
/_[!_]*.py
tmp_*
test_out*
D*tmp*
data/deploy_*.py
data/deploy_*.ps1
data/deploy_*.sh

# Live2D binary models (too large for git)
anima/dashboard/static/model/PurpleBird/

# Batch/shortcut files + machine-specific launchers (hardcode local abs paths)
ANIMA.bat
start_eva.bat
start_eva.vbs
launcher.py
test_config.py
create_shortcut.bat
uv.lock
eva-ui/node_modules
.claude/worktrees/
Eva_0.2.0_x64-setup.exe
