# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/

# Runtime data (local, regenerated at runtime)
data/anima.db
data/chroma/
data/logs/*
data/notes/*
data/workspace/*
data/uploads/*
data/credentials/
data/user_profile.md
data/environment.md
data/projects.md
data/node.json
data/scheduler.json
data/sync_watermarks.json
data/watchdog_heartbeat.json
data/spawn*.tar.gz
data/memory.db
data/anima.lock
data/voice/
data/evolution_checkpoint.json
!data/.gitkeep
!data/**/.gitkeep
!data/user_profile.md.example

# Local environment (machine-specific, NEVER commit)
local/env.yaml
!local/env.yaml.example

# Secrets (NEVER commit)
.env
.env.*
!.env.example

# Agent private memory (personal, not shared)
agents/*/feelings.md
agents/*/memory.md
agents/*/diary.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini
$null

