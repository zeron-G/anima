# ANIMA secrets — copy to .env (gitignored) and fill in. NEVER commit real values.
#
# All secrets flow through anima/secret_store.py (get_secret / resolve). Config
# files (config/default.yaml, local/env.yaml) hold only ${VAR} *references*; the
# actual values live here — or, in production, a vault (swap the backend via
# secret_store.set_secret_provider(); no business-code changes).

# ── LLM providers ──
# Anthropic: an API key (sk-ant-api…) OR an OAuth token. Method priority:
# AUTH_TOKEN > OAUTH_TOKEN > ~/.claude/.credentials.json (Claude Code login) > API_KEY.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_OAUTH_TOKEN=
# OpenAI cloud (openai/ models)
OPENAI_API_KEY=
# DeepSeek (deepseek/ models — OpenAI-compatible)
DEEPSEEK_API_KEY=

# ── Channels ──
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# ── Dashboard auth ──
# Blank password = auth DISABLED. JWT secret signs session tokens (set a stable
# random string so tokens survive restarts). Reference in config as
#   dashboard: { auth: { password: "${ANIMA_DASHBOARD_PASSWORD}", token: "${ANIMA_DASHBOARD_JWT_SECRET}" } }
ANIMA_DASHBOARD_PASSWORD=
ANIMA_DASHBOARD_JWT_SECRET=

# ── Distributed mesh + remote nodes ──
# Gossip mesh shared secret. Config: network.secret: "${ANIMA_NETWORK_SECRET}"
ANIMA_NETWORK_SECRET=
# Remote-node SSH password (prefer SSH keys!). Config: password: "${ANIMA_LAPTOP_SSH_PASSWORD}"
ANIMA_LAPTOP_SSH_PASSWORD=

# ── Data store ──
# Neon / Postgres connection string (contains a password → secret). When set,
# ANIMA's memory uses Postgres + pgvector instead of local SQLite + ChromaDB.
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Local Postgres fallback (offline failover + the test DB). Docker pgvector image:
#   docker run -d --name anima-pg -e POSTGRES_PASSWORD=... -e POSTGRES_DB=anima -p 5432:5432 pgvector/pgvector:pg17
# Use 127.0.0.1, NOT "localhost": on Windows "localhost" resolves to IPv6 ::1
# first and stalls the full connect timeout (~15s) before falling back to IPv4.
# LOCAL_DATABASE_URL=postgresql://postgres:pass@127.0.0.1:5432/anima

# ── Optional non-secret overrides ──
# ANTHROPIC_BASE_URL=
# OPENAI_API_BASE=
# DEEPSEEK_API_BASE=https://api.deepseek.com
