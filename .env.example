# ANIMA Environment Configuration
# Copy this file to .env and fill in your values.
# This file is gitignored — never commit real tokens.

# ── Authentication (pick ONE method, priority: 1 > 2 > 3) ──

# Method 1: Claude Code OAuth (auto-discovered)
# If you have Claude Code installed and logged in (claude login),
# ANIMA auto-discovers the token from ~/.claude/.credentials.json.
# No config needed.

# Method 2: OAuth Token (manual)
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-your-token-here

# Method 3: API Key (standard billing)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
