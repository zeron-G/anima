# ═══════════════════════════════════════
# ANIMA Local Environment Configuration
# ═══════════════════════════════════════
#
# Copy this file to local/env.yaml and fill in your values.
# local/env.yaml is GITIGNORED — your personal settings stay local.

# ── Machine ──
machine:
  hostname: ""
  platform: "windows"  # windows / linux

# ── Python ──
python:
  executable: ""  # Leave empty to auto-detect from sys.executable

# ── Network ──
network:
  secret: ""
  peers: []
  remote_nodes: []
  # Example with multi-host fallback:
  # remote_nodes:
  #   - name: "laptop"
  #     host: "100.x.x.x"    # primary (e.g. Tailscale)
  #     hosts:
  #       - "192.168.x.x"    # LAN fallback
  #     user: "username"
  #     password: "password"

# ── Edge / Robot Dog ──
# Run on the robot with:
#   ANIMA_PROFILE=edge-pidog python -m anima --edge
# Typical machine-specific overrides for the robot:
# runtime:
#   labels: ["edge", "field"]
# network:
#   peers: ["192.168.1.10:9420"]   # desktop supervisor or relay node
# dashboard:
#   auth:
#     token: "set-a-shared-token"
# robotics:
#   nodes:
#     - id: "pidog-local"
#       base_urls: ["http://127.0.0.1:8888"]
#       metadata:
#         lan_hint: "192.168.1.174:8888"

# ── TTS ──
tts:
  model_id: "Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice"
  speaker: "Vivian"
  language: "Chinese"
  instruct: ""

# ── User Profile ──
user:
  name: ""
  timezone: ""
