# ═══════════════════════════════════════
# ANIMA Local Environment Configuration
# ═══════════════════════════════════════
#
# Copy this file to local/env.yaml and fill in your values.
# local/env.yaml is GITIGNORED — your personal settings stay local.

# ── Machine ──
machine:
  hostname: ""
  platform: "windows"  # windows / linux

# ── Python ──
python:
  executable: ""  # Leave empty to auto-detect from sys.executable

# ── Network ──
network:
  secret: ""
  peers: []
  remote_nodes: []
  # Example with multi-host fallback:
  # remote_nodes:
  #   - name: "laptop"
  #     platform: "windows"   # windows / linux
  #     host: "100.x.x.x"    # primary (e.g. Tailscale)
  #     hosts:
  #       - "192.168.x.x"    # LAN fallback
  #     user: "username"
  #     password: "password"
  #     python_cmd: "E:\\codesupport\\anaconda\\envs\\anima\\python.exe"
  #     install_dir: "C:\\Users\\username\\an"
  #     profile: "default"   # or "edge-pidog"
  #     edge_mode: false
  #     install_service: true
  #     include_env: false
  #     local_overrides:
  #       machine:
  #         hostname: "MY_LAPTOP"
  #         platform: "windows"
  #       network:
  #         peers:
  #           - "192.168.1.10:9420"
  #
  #   - name: "pidog"
  #     platform: "linux"
  #     host: "100.x.x.x"
  #     hosts:
  #       - "192.168.x.x"
  #     user: "eva"
  #     password: "password"
  #     python_cmd: "python3"
  #     install_dir: "~/.anima-edge"
  #     profile: "edge-pidog"
  #     edge_mode: true
  #     install_service: true
  #     include_env: false
  #     local_overrides:
  #       machine:
  #         hostname: "PiDog"
  #         platform: "linux"
  #       network:
  #         peers:
  #           - "192.168.1.10:9420"
  #       runtime:
  #         labels: ["edge", "field"]

# ── Edge / Robot Dog ──
# Run on the robot with:
#   ANIMA_PROFILE=edge-pidog python -m anima --edge
# Typical machine-specific overrides for the robot:
# runtime:
#   labels: ["edge", "field"]
# network:
#   peers: ["192.168.1.10:9420"]   # desktop supervisor or relay node
# dashboard:
#   auth:
#     token: "set-a-shared-token"
# robotics:
#   nodes:
#     - id: "pidog-local"
#       base_urls: ["http://127.0.0.1:8888"]
#       metadata:
#         lan_hint: "192.168.1.174:8888"

# ── TTS ──
tts:
  model_id: "Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice"
  speaker: "Vivian"
  language: "Chinese"
  instruct: ""

# ── User Profile ──
user:
  name: ""
  timezone: ""
